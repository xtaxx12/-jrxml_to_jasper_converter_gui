<?xml version="1.0" encoding="UTF-8"?>
<!-- Created with Jaspersoft Studio version 6.21.2.final using JasperReports Library version 6.2.1  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rptetqmasterx2_ng" language="groovy" pageWidth="360" pageHeight="180" columnWidth="320" leftMargin="20" rightMargin="20" topMargin="0" bottomMargin="0" uuid="8d80ed91-9f44-41dc-8bae-2b7370b9fbf5">
	<property name="ireport.zoom" value="2.3579476910000023"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="getcodigo" class="java.lang.Long">
		<defaultValueExpression><![CDATA[0]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[WITH
parametros AS (
	SELECT 	$P{getcodigo}::bigint AS getcodigo
)
,secuencia AS (
	UPDATE sysprom.rcp_lote SET lot_max_secuencia = ('{"umin":"'||numin||'","mast":"'||nmastmax||'"}')::jsonb
	FROM (
		SELECT
			COALESCE((lot.lot_max_secuencia->>'umin')::int,0) AS numin
			,COALESCE((lot.lot_max_secuencia->>'mast')::int,0)+1 AS nmast
			,TRUNC(COALESCE((lot.lot_max_secuencia->>'mast')::int,0)
					+geti.get_cantidad) AS nmastmax
			,lot.lot_codigo AS lotcodigo
			,par.getcodigo
			,COALESCE(geti.get_reproceso, 0) AS getreproceso
		FROM parametros AS par
		INNER JOIN sysprom.gen_etiquetas as geti ON geti.get_codigo = par.getcodigo AND get_estado = 'S'
			AND coalesce(get_tipo,'') = '' AND coalesce(geti.get_tracking_reimpresion ,'') = ''
		INNER JOIN sysprom.rcp_lote AS lot ON lot.lot_codigo = geti.lot_codigo
	) AS tt
	WHERE lot_codigo = tt.lotcodigo
	RETURNING nmast,nmastmax,getcodigo,getreproceso
)
,upedido AS (
	UPDATE sysprom.gen_etiquetas SET get_estado = 'A'
	FROM (
		SELECT getcodigo FROM parametros
	) AS tt
	WHERE get_codigo = tt.getcodigo AND get_estado = 'S'
	RETURNING *
)
,ietiquetas AS (
	INSERT INTO sysprom.gen_etiqueta_detalle (getd_tracking, get_codigo, getd_estado_etiqueta)
	(
		SELECT	generate_series(sec.nmast,sec.nmastmax::bigint) as tracking
			,getcodigo, CASE WHEN getreproceso = 0 THEN 'A'::TEXT ELSE 'I'::TEXT END as getdestadoetiqueta
		FROM secuencia AS sec
		WHERE (SELECT COUNT(*) FROM upedido) > 0
	)
	RETURNING *
)
,genetiquetas AS (
	SELECT  getdcodigo
		,getdtracking
		,getcodigo
		,nmast,nmastmax
		,clase, talla
		,norden
		,presentacioncam
	FROM (
		SELECT getdcodigo
			,getdtracking
			,getcodigo
			,nmast,nmastmax
			,prod.clase
			,CASE WHEN dtall.dtall_codigo IS NOT NULL THEN dtall.dtall_denominacion ELSE prod.talla END AS talla
			,CASE WHEN prd.tdet_codigo_presentacion_cam = 63 THEN '*'
				  WHEN prd.tdet_codigo_presentacion_cam = 64 THEN '***'
				  WHEN prd.tdet_codigo_presentacion_cam = 65 THEN '**'
				  WHEN prd.tdet_codigo_presentacion_cam = 495 THEN '****'
				  ELSE ''
				  END AS presentacioncam
			,ROW_NUMBER() OVER(ORDER BY getdtracking) AS norden
		FROM (
			SELECT getd_codigo::TEXT AS getdcodigo
				,getd_tracking AS getdtracking
				,get_codigo AS getcodigo
				,nmast,nmastmax
			FROM ietiquetas
			INNER JOIN secuencia AS sec ON TRUE
			UNION
			SELECT getd_codigo::TEXT AS getdcodigo
				,getd_tracking AS getdtracking
				,eti.get_codigo AS getcodigo
				,COUNT(*) OVER() AS nmast
				,MAX(getd_tracking) OVER() AS nmastmax
			FROM parametros AS par
			INNER JOIN sysprom.gen_etiquetas AS eti ON eti.get_codigo = par.getcodigo AND COALESCE(eti.get_tipo, '') = ''
				AND COALESCE(eti.get_tracking_reimpresion,'') = ''
			INNER JOIN sysprom.gen_etiqueta_detalle AS et ON et.get_codigo = par.getcodigo
			UNION
			SELECT getd_codigo::TEXT AS getdcodigo
				,getd_tracking AS getdtracking
				,et.get_codigo AS getcodigo
				,COUNT(*) OVER() AS nmast
				,MAX(getd_tracking) OVER() AS nmastmax
			FROM parametros AS par
			INNER JOIN sysprom.gen_etiquetas AS eti ON eti.get_codigo = par.getcodigo AND COALESCE(eti.get_tipo, 'R') = 'R'
				AND COALESCE(eti.get_tracking_reimpresion,'') != ''
			INNER JOIN sysprom.gen_etiqueta_detalle AS et ON  et.getd_codigo = any(string_to_array(eti.get_tracking_reimpresion,',')::bigint[])
		) AS tt
		INNER JOIN sysprom.gen_etiquetas AS eti ON eti.get_codigo = tt.getcodigo
		INNER JOIN sysprom.getproductoinfo(eti.ptall_codigo) AS prod ON TRUE
		INNER JOIN sysprom.gen_producto_tallas AS ptall ON ptall.ptall_codigo = eti.ptall_codigo
		INNER JOIN sysprom.gen_producto AS prd ON prd.prod_codigo = ptall.prod_codigo
		LEFT JOIN sysprom.gen_detalle_talla AS dtall ON dtall.dtall_codigo  = eti.dtall_codigo
	) AS tt
)
,genserie AS (
	SELECT  getdcodigo,getdtracking
		,getcodigo,nmast,nmastmax
		,clase, talla,norden,presentacioncam
	FROM genetiquetas
	UNION
	SELECT getdcodigo,getdtracking
		,getcodigo,nmast,nmastmax
		,clase, talla,norden,presentacioncam
	FROM (
		SELECT  'SOLICITUD'::text AS getdcodigo
			,0::bigint AS getdtracking
			,0::bigint AS getcodigo
			,0::bigint AS nmast
			,0::bigint AS nmastmax
			,psol.pers_razon_social::TEXT AS clase
			,to_char(eti.get_fecha_hora_envio, 'DD/MM/YYYY HH24:MI')::TEXT AS talla
			,max(norden)+1 AS norden
			,''::TEXT AS presentacioncam
		FROM genetiquetas AS geti
		INNER JOIN sysprom.gen_etiquetas AS eti ON eti.get_codigo = geti.getcodigo
		INNER JOIN sysprom.gen_persona AS psol ON psol.pers_codigo = eti.pers_codigo_realiza
		GROUP BY psol.pers_razon_social,eti.get_fecha_hora_envio
		LIMIT 1
	) AS tt
	ORDER BY norden
)
SELECT
	'M'||getdcodigo AS dato1
	,clase AS clase1
	,talla AS talla1
	,presentacioncam AS presentacioncam1
FROM genserie
ORDER BY norden]]>
	</queryString>
	<field name="dato1" class="java.lang.String"/>
	<field name="clase1" class="java.lang.String"/>
	<field name="talla1" class="java.lang.String"/>
	<field name="presentacioncam1" class="java.lang.String"/>
	<background>
		<band splitType="Stretch"/>
	</background>
	<detail>
		<band height="180" splitType="Stretch">
			<image>
				<reportElement x="43" y="12" width="80" height="68" uuid="06631f40-be5b-42f2-bade-b7a7f7160f67">
					<property name="com.jaspersoft.studio.unit.width" value="px"/>
					<property name="com.jaspersoft.studio.unit.height" value="px"/>
					<printWhenExpression><![CDATA[$F{dato1}.compareTo( "MSOLICITUD" ) != 0]]></printWhenExpression>
				</reportElement>
				<imageExpression><![CDATA[com.google.zxing.client.j2se.MatrixToImageWriter.toBufferedImage(
new com.google.zxing.qrcode.QRCodeWriter().encode(
$F{dato1},
com.google.zxing.BarcodeFormat.QR_CODE, 300, 300))]]></imageExpression>
			</image>
			<textField isStretchWithOverflow="true">
				<reportElement x="-17" y="80" width="170" height="30" uuid="41640a19-a09a-4c2b-8d01-82d33c55fc07">
					<printWhenExpression><![CDATA[$F{dato1}.compareTo( "MSOLICITUD" ) != 0]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle" rotation="None" markup="html">
					<font size="12" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{presentacioncam1}+"  "+$F{dato1}]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
				<reportElement x="0" y="30" width="136" height="120" uuid="9ffd82f4-7f24-4fd0-846b-6fbf58f41543">
					<printWhenExpression><![CDATA[$F{dato1}.compareTo( "MSOLICITUD" ) == 0]]></printWhenExpression>
				</reportElement>
				<textElement textAlignment="Center" verticalAlignment="Middle" rotation="None" markup="html">
					<font size="10" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA["SOLICITUD<br/>"+$F{clase1}+"<br/>"+$F{talla1}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
